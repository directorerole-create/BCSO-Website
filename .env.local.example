# Copy this file to .env.local and fill in your values

# Supabase — get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only — NEVER expose to client)
# Found in Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Shared secret for Google Apps Script → API webhook auth
# Generate a strong random string: https://generate-secret.vercel.app/32
SYNC_SECRET=your_random_secret_here
